{
  "config": {
    "default": true,
    // long lines are common in README tables and code blocks
    "MD013": false,
    // inline HTML is used in README logo
    "MD033": false,
    // README/AGENTS don't start with a heading (logo image / redirect)
    "MD041": false
  },
  "ignores": ["node_modules/", "CHANGELOG.md", ".claude/"]
}
