{
  "name": "@capotej/harness",
  "version": "1.4.1",
  "description": "Portable environment for running coding agents in a container",
  "bin": {
    "harness": "bin/harness.js"
  },
  "files": ["bin/"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/capotej/harness.git"
  },
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "lint": "pnpm lint:ts && pnpm lint:md && pnpm lint:sh && pnpm lint:docker && pnpm lint:actions",
    "lint:ts": "biome check .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:sh": "shellcheck entrypoint.sh entrypoint-opencode.sh entrypoint-hermes.sh",
    "lint:docker": "hadolint Dockerfile Dockerfile.opencode Dockerfile.hermes",
    "lint:actions": "actionlint",
    "format": "biome format --write ."
  },
  "dependencies": {
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.6.0",
    "markdownlint-cli2": "0.17.2",
    "typescript": "^6.0.2"
  }
}
